<form action="/<%= formAction %>" method="post" class="sign-up">
    <div>
        <label for="username">Username: </label>
        <input type="text" name="username" id="username" minlength="3" required>
    </div>
    <div>
        <label for="password">Password: </label>
        <input type="password" name="password" id="password" minlength="6" required>
    </div>
    <div>
        <label for="confirmPassword">Confirm Password: </label>
        <input type="password" name="confirmPassword" id="confirmPassword" minlength="6" required>
    </div>
    <button type="submit" class="link_btn"><%= formBtnText %></button>
</form>