<form action="/<%= path %>" method="post" enctype="multipart/form-data">
<div>
    <label for="file_name">Choose an image file to upload (png, jpg or jpeg)</label>
    <input type="file" name="file_name" id="file_name" accept=".jpg, .jpeg, .png" multiple required>
</div>
<button type="submit">Upload</button>
</form>